# Database (Railway PostgreSQL 또는 로컬 SQLite)
DATABASE_URL=sqlite:///./insight.db
# 배포 시: postgresql://user:password@host:5432/dbname

# OpenAI
OPENAI_API_KEY=sk-...

# Supabase
SUPABASE_PROJECT_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_ISS=https://xxxxxxxx.supabase.co/auth/v1
SUPABASE_JWT_AUD=authenticated

# CORS - 배포된 프론트엔드 URL
FRONTEND_URL=https://your-app.vercel.app

# Debug (로컬 개발용, 배포 시 false)
DEBUG_AUTH=false
